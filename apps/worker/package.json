{
  "name": "@eva/worker",
  "version": "0.0.0",
  "private": true,
  "description": "Eva background worker — Inngest durable functions (BRD 9.3)",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "inngest:dev": "inngest-cli dev -u http://localhost:3002/api/inngest"
  },
  "dependencies": {
    "@eva/configuration": "workspace:*",
    "express": "^5.1.0",
    "inngest": "^3.35.0",
    "pino": "^10.3.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@eva/testing": "workspace:*",
    "@types/express": "^5.0.0",
    "@types/node": "^22.15.0",
    "inngest-cli": "^1.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
