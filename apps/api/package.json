    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "helmet": "^8.1.0",
    "nestjs-pino": "^4.4.0",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "pino-pretty": "^13.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@eva/testing": "workspace:*",
    "@types/express": "^5.0.0",
