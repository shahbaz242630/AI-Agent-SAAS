{
  "name": "eva-platform",
  "version": "0.0.0",
  "private": true,
  "description": "Eva — AI business communications platform (BRD v1.2)",
  "packageManager": "pnpm@10.34.5",
  "engines": {
    "node": ">=22 <23",
    "pnpm": ">=10.16"
  },
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r run build",
    "lint": "pnpm -r --if-present run lint",
    "typecheck": "pnpm -r --if-present run typecheck",
    "test": "pnpm -r --if-present run test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "pnpm --filter @eva/database run db:generate",
    "db:migrate": "pnpm --filter @eva/database run db:migrate",
    "db:seed": "pnpm --filter @eva/database run db:seed"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "@sentry/cli",
      "esbuild",
      "prisma",
      "protobufjs",
      "sharp",
      "unrs-resolver"
    ],
    "overrides": {
      "next>postcss": ">=8.5.10",
      "next>sharp": ">=0.35.0",
      "tar": ">=7.5.19",
      "engine.io": ">=6.6.7",
      "ws": ">=8.21.0",
      "esbuild": ">=0.25.0",
      "find-my-way": ">=9.7.0"
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "prettier": "^3.5.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.0.0"
  }
}
