# ── Eva platform — example environment file ──────────────────────────────
# Copy to .env for local dev. NEVER commit a real .env (see .gitignore).
# Real secrets live in Railway / Supabase / GitHub Environments (BRD 9.10).

# Shared
NODE_ENV=development
LOG_LEVEL=info

# API (apps/api)
PORT=3001
# Postgres — local Docker Compose default (used by @eva/database since Slice 0.2)
DATABASE_URL=postgresql://eva:eva@localhost:5432/eva
# Runtime API connection as the eva_app role (NOBYPASSRLS) — RLS applies (Slice 0.3)
APP_DATABASE_URL=postgresql://eva_app:eva_app@localhost:5432/eva

# Worker (apps/worker) — Trigger.dev v4 (locked 2026-07-22); tasks run on Trigger.dev Cloud
# Project ref from the Trigger.dev dashboard; secret key stays EMPTY here (Slice 0.4/staging)
TRIGGER_PROJECT_REF=
TRIGGER_SECRET_KEY=

# Web (apps/web)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Supabase (Slice 0.3) — placeholders only
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Web browser-side Supabase access (Slice 0.5) — same project; the anon key is public-by-design
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Sentry (Slice 0.4) — placeholders only. DSNs are public-by-design.
SENTRY_DSN_API=
# Feeds NEXT_PUBLIC_SENTRY_DSN for the browser bundle via apps/web/next.config.ts
SENTRY_DSN_WEB=
SENTRY_DSN_WORKER=
# CI-only source-map upload token (GitHub/Railway secret). NEVER put the real value here.
SENTRY_AUTH_TOKEN=
