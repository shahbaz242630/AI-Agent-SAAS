# ── Eva platform — example environment file ──────────────────────────────
# Copy to .env for local dev. NEVER commit a real .env (see .gitignore).
# Real secrets live in Railway / Supabase / GitHub Environments (BRD 9.10).

# Shared
NODE_ENV=development
LOG_LEVEL=info

# API (apps/api)
PORT=3001
# Postgres — local Docker Compose default (Slice 0.2 will use this)
DATABASE_URL=postgresql://eva:eva@localhost:5432/eva

# Worker (apps/worker)
WORKER_PORT=3002
# Inngest dev server URL when running `npx inngest-cli dev` (cloud keys added in Slice 0.4)
INNGEST_DEV=1

# Web (apps/web)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Supabase (Slice 0.3) — placeholders only
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Sentry (Slice 0.4) — placeholders only
SENTRY_DSN_API=
SENTRY_DSN_WEB=
SENTRY_DSN_WORKER=
