# Eva Web — production image (BRD 9.11: Docker packaging; Railway deploys this).
# Build context is the REPOSITORY ROOT (pnpm workspace).
FROM node:22-alpine AS base
RUN corepack enable && corepack prepare pnpm@10.34.5 --activate
WORKDIR /app

FROM base AS build
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml tsconfig.base.json ./
COPY packages ./packages
COPY apps/web ./apps/web
RUN pnpm install --frozen-lockfile --filter @eva/web...
# NEXT_PUBLIC_* values are inlined into the browser bundle at build time, so
# they must arrive as Docker build args (Railway injects service variables as
# build args ONLY when declared with ARG — docs.railway.com/builds/dockerfiles).
ARG NEXT_PUBLIC_SUPABASE_URL=""
ARG NEXT_PUBLIC_SUPABASE_ANON_KEY=""
ARG NEXT_PUBLIC_API_URL=""
# SENTRY_DSN_WEB feeds NEXT_PUBLIC_SENTRY_DSN via apps/web/next.config.ts (BRD 14).
ARG SENTRY_DSN_WEB=""
ENV NEXT_PUBLIC_SUPABASE_URL=$NEXT_PUBLIC_SUPABASE_URL \
    NEXT_PUBLIC_SUPABASE_ANON_KEY=$NEXT_PUBLIC_SUPABASE_ANON_KEY \
    NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL \
    SENTRY_DSN_WEB=$SENTRY_DSN_WEB
RUN pnpm --filter @eva/web... run build

FROM base AS runner
ENV NODE_ENV=production
COPY --from=build /app ./
EXPOSE 3000
CMD ["pnpm", "--filter", "@eva/web", "run", "start"]
