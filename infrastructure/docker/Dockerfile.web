# Eva Web — production image (BRD 9.11: Docker packaging; Railway deploys this).
# Build context is the REPOSITORY ROOT (pnpm workspace).
FROM node:22-alpine AS base
RUN corepack enable && corepack prepare pnpm@10.34.5 --activate
WORKDIR /app

FROM base AS build
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml tsconfig.base.json ./
COPY packages ./packages
COPY apps/web ./apps/web
RUN pnpm install --frozen-lockfile --filter @eva/web...
# SENTRY_DSN_WEB must be set at build time — next.config.ts bridges it to
# NEXT_PUBLIC_SENTRY_DSN for the browser bundle (BRD 14). Empty = disabled.
RUN pnpm --filter @eva/web... run build

FROM base AS runner
ENV NODE_ENV=production
COPY --from=build /app ./
EXPOSE 3000
CMD ["pnpm", "--filter", "@eva/web", "run", "start"]
